# ============================================
# X-Education Scheduler Bot — Environment Variables
# Copy this file to `.env` and fill in real values.
# ============================================

# ===== Telegram bot core =====
# The API token of your new scheduler bot (from @BotFather)
BOT_TOKEN=123456:replace_me_with_token_from_BotFather

# Your numeric Telegram user ID (get from @userinfobot)
ADMIN_ID=000000000

# ===== Destination =====
# The new Telegram channel username (with @) where approved posts will be sent
TARGET_CHANNEL_USERNAME=@THEXEducation

# ===== Site & Brand =====
# Your main website URL (gated read page)
WEBSITE_URL=https://videoslk.eu.cc

# The link to the main video bot (if users want to go there)
MAIN_BOT_LINK=https://t.me/ukussa_69_bot

# The link to the owner / support bot (from your template)
OWNER_BOT_LINK=https://t.me/Ukussa_Admin49_Bot
